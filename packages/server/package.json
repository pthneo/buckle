{
  "name": "@buckle/server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "portless buckle vite",
    "build": "bun build src/index.ts --outdir dist --target bun --minify --sourcemap=external",
    "test": "bun test",
    "check": "bun test",
    "ui": "vite build",
    "server": "CONFIG_PATH=./dev/buckle.yml portless api.buckle bun --hot src/index.ts",
    "services": "docker compose up -d -f /dev/docker-compose.yml"
  },
  "private": true,
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/js-yaml": "^4.0.9",
