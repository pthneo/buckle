{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".mintlify/**"]
    },
    "@buckle/server#services": {
      "cache": false
    },
    "@buckle/server#dev": {
      "cache": false,
      "persistent": true
    },
    "@buckle/server#server": {
      "cache": false,
      "persistent": true
    },
    "test": {},
    "check": {}
  }
}
