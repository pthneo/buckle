{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".mintlify/**"]
    },
    "server#dev": {
      "dependsOn": ["server#server", "server#services"],
      "cache": false,
      "persistent": true
    },
    "test": {},
    "check": {}
  }
}
